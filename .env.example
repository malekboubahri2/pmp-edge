# pmp-edge configuration. Copy to .env (gitignored) and adjust.

# ── Base domain ──────────────────────────────────────────────────────────────
# Every app on this Pi is a subdomain of this: inspection.${BASE_DOMAIN},
# andon.${BASE_DOMAIN}, qcl1.${BASE_DOMAIN}, … A single wildcard DNS record
# (*.${BASE_DOMAIN}) points all of them at the Pi, so adding an app needs no
# DNS change.
#
# Use a PRIVATE suffix that is NOT a real public domain — a wildcard here
# shadows the whole domain on this LAN. Good: pmp.lan, pmp.internal, pmp.
# Avoid: .local (collides with mDNS/Bonjour) and any real domain you also need
# to reach from the plant (e.g. a public pmp.com website).
BASE_DOMAIN=pmp.lan

# ── Upstream resolver ────────────────────────────────────────────────────────
# Where dnsmasq forwards every non-local name. Point at the plant gateway/router
# (or a public DNS) so normal internet/LAN lookups still work.
UPSTREAM_DNS=1.1.1.1

# ── LAN interface (optional) ─────────────────────────────────────────────────
# Auto-detected from the default route if unset. Pin it only if detection picks
# the wrong NIC (e.g. you want eth0, not wlan0).
# LAN_IFACE=eth0
